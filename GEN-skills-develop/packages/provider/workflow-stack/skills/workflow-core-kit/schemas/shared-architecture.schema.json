{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gen-skills.local/workflow-core/shared-architecture.schema.json",
  "title": "Shared Architecture.Schema",
  "schema_kind": "workflow-template-contract",
  "template_path": "templates/skills/shared/architecture.template.md",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_path",
    "scope",
    "phase"
  ],
  "properties": {
    "template_path": {
      "const": "templates/skills/shared/architecture.template.md"
    },
    "scope": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "required_markdown_sections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "required_tokens": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
