.idea/
.repo/
.DS_Store

__pycache__/
*.py[cod]
.pytest_cache/

.venv/
venv/

# npm dependency and cache directories
node_modules/
.npm/
.pnpm-store/

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
